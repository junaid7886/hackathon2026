{
    "version": 2,
    "public": true,
    "buildCommand": "npm run build || true",
    "outputDirectory": "./",
    "env": {
        "NODE_ENV": "production"
    },
    "headers": [
        {
            "source": "/css/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600"
                }
            ]
        },
        {
            "source": "/js/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600"
                }
            ]
        }
    ],
    "routes": [
        {
            "src": "/api/auth.*",
            "dest": "/api/auth.js"
        },
        {
            "src": "/api/activities.*",
            "dest": "/api/activities.js"
        },
        {
            "src": "/api/health-records.*",
            "dest": "/api/health-records.js"
        },
        {
            "src": "/api/chat.*",
            "dest": "/api/chat.js"
        },
        {
            "src": "/api/stats.*",
            "dest": "/api/stats.js"
        },
        {
            "src": "/(.*\\..*)",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}